<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="${basedir}/logs/nlog-internal.log">

  <targets>
    <!-- Colored console output for development -->
    <target xsi:type="ColoredConsole"
            name="console"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message} ${exception:format=tostring}" />

    <!-- Daily rolling log file — general -->
    <target xsi:type="File"
            name="file"
            fileName="${basedir}/logs/${processname}-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger} | ${message} ${exception:format=tostring}"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="7"
            concurrentWrites="true"
            keepFileOpen="false" />

    <!-- Separate error-only log file with full inner exception detail -->
    <target xsi:type="File"
            name="error-file"
            fileName="${basedir}/logs/${processname}-error-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger} | ${message} ${exception:format=tostring:innerFormat=tostring:maxInnerExceptionLevel=5}" />
  </targets>

  <rules>
    <!-- Suppress noisy Microsoft framework logs -->
    <logger name="Microsoft.*"         maxlevel="Info" final="true" />
    <logger name="Microsoft.Hosting.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*"   maxlevel="Info" final="true" />

    <!-- App logs: Debug and above → console + file -->
    <logger name="*" minlevel="Debug" writeTo="console,file" />

    <!-- Error and above → dedicated error file -->
    <logger name="*" minlevel="Error" writeTo="error-file" />
  </rules>

</nlog>
