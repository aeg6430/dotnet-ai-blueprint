{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://127.0.0.1:5173",
      "http://127.0.0.1:5174"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "Authorization"
    ]
  },
  "Jwt": {
    "SecretKey": "YOUR_DEV_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "YourAppName",
    "Audience": "YourAppNameClient",
    "ExpiryMinutes": 480
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=YOUR_DB_Dev;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "InventoryApi": {
    "BaseUrl": "https://inventory-api.local/",
    "TimeoutSeconds": 10,
    "VerificationPath": "inventory/verify"
  },
  "PricingApi": {
    "BaseUrl": "https://pricing-api.local/",
    "TimeoutSeconds": 8,
    "QuotePath": "pricing/quote"
  },
  "ShipmentApi": {
    "BaseUrl": "https://shipment-api.local/",
    "TimeoutSeconds": 12,
    "CreateShipmentPath": "shipments"
  },
  "PaymentApi": {
    "BaseUrl": "https://payment-api.local/",
    "TimeoutSeconds": 12,
    "AuthorizePath": "payments/authorize",
    "ApiKeyHeaderName": "X-Api-Key",
    "ApiKey": "replace-me-payment-key"
  },
  "WebhookDelivery": {
    "BaseUrl": "https://webhook-target.local/",
    "TimeoutSeconds": 10,
    "DeliveryPath": "webhooks/outbox-delivery",
    "SigningSecret": "replace-me-webhook-secret"
  },
  "MessagePublisher": {
    "BrokerName": "LocalBroker",
    "TopicName": "domain-events",
    "PublishTimeoutSeconds": 8
  },
  "OutboxDelivery": {
    "BatchSize": 20,
    "PollIntervalSeconds": 5
  }
}
