{
  "Cors": {
    "AllowedOrigins": [],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "Authorization"
    ]
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "",
    "Audience": "",
    "ExpiryMinutes": 480
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "InventoryApi": {
    "BaseUrl": "",
    "TimeoutSeconds": 10,
    "VerificationPath": "inventory/verify"
  },
  "PricingApi": {
    "BaseUrl": "",
    "TimeoutSeconds": 8,
    "QuotePath": "pricing/quote"
  },
  "ShipmentApi": {
    "BaseUrl": "",
    "TimeoutSeconds": 12,
    "CreateShipmentPath": "shipments"
  },
  "PaymentApi": {
    "BaseUrl": "",
    "TimeoutSeconds": 12,
    "AuthorizePath": "payments/authorize",
    "ApiKeyHeaderName": "X-Api-Key",
    "ApiKey": ""
  },
  "WebhookDelivery": {
    "BaseUrl": "",
    "TimeoutSeconds": 10,
    "DeliveryPath": "webhooks/outbox-delivery",
    "SigningSecret": ""
  },
  "MessagePublisher": {
    "BrokerName": "ExampleBroker",
    "TopicName": "domain-events",
    "PublishTimeoutSeconds": 8
  },
  "OutboxDelivery": {
    "BatchSize": 20,
    "PollIntervalSeconds": 10
  },
  "RequestScreening": {
    "Enabled": false,
    "ReportOnly": true,
    "BlockStatusCode": 403,
    "ProblemType": "https://httpstatuses.com/403",
    "ProblemTitle": "Request blocked",
    "ProblemDetail": "This request has been blocked by a temporary security control.",
    "BlockedPathPrefixes": [],
    "BlockedMethods": [],
    "BlockedQueryKeys": [],
    "BlockedQueryValueFragments": [],
    "AllowlistedPathPrefixes": [
      "/health",
      "/ready"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
