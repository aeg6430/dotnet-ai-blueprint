{
  "PaymentApi": {
    "BaseUrl": "https://payment-api.local/",
    "TimeoutSeconds": 12,
    "AuthorizePath": "payments/authorize"
  },
  "WebhookDelivery": {
    "BaseUrl": "https://webhook-target.local/",
    "TimeoutSeconds": 10,
    "DeliveryPath": "webhooks/outbox-delivery"
  },
  "MessagePublisher": {
    "BrokerName": "DemoBroker",
    "TopicName": "domain-events",
    "PublishTimeoutSeconds": 8
  },
  "OutboxDelivery": {
    "BatchSize": 20,
    "PollIntervalSeconds": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
